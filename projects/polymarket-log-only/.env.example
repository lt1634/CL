# 複製為 .env 再填（唔 commit .env）
# 詳解：memory/kb/openclaw-polymarket-log-only-spec-and-env.md

# OpenClaw Gateway（若其他腳本要用）
# OPENCLAW_GATEWAY_TOKEN=

# HTTP 代理（住宅代理等）— 視情況
# HTTPS_PROXY=http://user:pass@host:port
# HTTP_PROXY=http://user:pass@host:port
# NO_PROXY=127.0.0.1,localhost

# CLOB 重試（你嘅拉價／下單腳本讀呢啲名就得，名稱要同自己 code 對齊）
CLOB_MAX_RETRIES=10

# Polygon RPC（只讀鏈或實盤先需要）
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/xxx

# 自訂 log 目錄（預設下面呢個）
# POLY_LOG_ONLY_DIR=/Users/timnewmac/.openclaw/workspace/memory/polymarket/log-only
